generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  role         String        @default("Employee")
  phone        String?       @default("")
  skills       String[]      @default([])
  resumeUrl    String?       @default("")
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("users")
}

model Employee {
  id               String         @id @default(uuid())
  employeeCode     String         @unique
  name             String
  role             String         @default("")
  department       String         @default("")
  email            String
  phone            String         @default("")
  location         String         @default("")
  status           String         @default("Active")
  salary           Float          @default(0)
  performanceScore Float          @default(0)
  attendanceRate   Float          @default(0)
  sentimentScore   Float          @default(0)
  skills           String[]       @default([])
  workload         Float          @default(0)
  attritionRisk    String         @default("Low")
  attendance       Attendance[]
  leaves           Leave[]
  payrolls         Payroll[]
  notifications    Notification[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("employees")
}

model Attendance {
  id             String   @id @default(uuid())
  attendanceCode String   @unique
  employeeCode   String
  employee       Employee @relation(fields: [employeeCode], references: [employeeCode], onDelete: Cascade, onUpdate: Cascade)
  date           String
  checkIn        String?
  checkOut       String?
  status         String   @default("Present")
  geo            String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([employeeCode])
  @@map("attendance")
}

model Leave {
  id           String   @id @default(uuid())
  leaveCode    String   @unique
  employeeCode String
  employee     Employee @relation(fields: [employeeCode], references: [employeeCode], onDelete: Cascade, onUpdate: Cascade)
  type         String   @default("Casual")
  from         String
  to           String
  reason       String   @default("")
  status       String   @default("Pending")
  balanceAfter Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeCode])
  @@map("leaves")
}

model Payroll {
  id           String   @id @default(uuid())
  payrollCode  String   @unique
  employeeCode String
  employee     Employee @relation(fields: [employeeCode], references: [employeeCode], onDelete: Cascade, onUpdate: Cascade)
  month        String
  base         Float    @default(0)
  bonus        Float    @default(0)
  deductions   Float    @default(0)
  net          Float    @default(0)
  benchmark    Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeCode])
  @@map("payrolls")
}

model Recruitment {
  id           String        @id @default(uuid())
  jobCode      String        @unique
  title        String
  department   String        @default("")
  status       String        @default("Open")
  applicants   Int           @default(0)
  priority     String        @default("Medium")
  description  String        @default("")
  requirements String        @default("")
  location     String        @default("")
  salary       String        @default("")
  closingDate  String?
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("recruitment")
}

model Application {
  id              String      @id @default(uuid())
  applicationCode String      @unique
  jobCode         String
  job             Recruitment @relation(fields: [jobCode], references: [jobCode], onDelete: Cascade, onUpdate: Cascade)
  name            String
  score           Float       @default(0)
  stage           String      @default("New")
  candidateId     String?
  candidate       User?       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  resumeUrl       String?     @default("")
  coverLetter     String?     @default("")
  aiScore         Float       @default(0)
  aiSummary       String      @default("")
  recruiterNotes  String      @default("")
  interviews      Interview[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([jobCode])
  @@index([candidateId])
  @@map("applications")
}

model Interview {
  id            String              @id @default(uuid())
  interviewCode String              @unique
  applicationId String
  application   Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  roundType     String              @default("HR")
  scheduledAt   String
  interviewers  String[]            @default([])
  location      String              @default("")
  status        String              @default("Scheduled")
  notes         String              @default("")
  feedbacks     InterviewFeedback[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([applicationId])
  @@map("interviews")
}

model InterviewFeedback {
  id             String    @id @default(uuid())
  interviewId    String
  interview      Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  reviewerName   String
  communication  Float     @default(0)
  technical      Float     @default(0)
  cultureFit     Float     @default(0)
  leadership     Float     @default(0)
  overallScore   Float     @default(0)
  recommendation String    @default("Hold")
  comments       String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([interviewId])
  @@map("interview_feedback")
}

model Notification {
  id         String    @id @default(uuid())
  type       String    @default("info")
  severity   String    @default("low")
  title      String
  detail     String    @default("")
  message    String    @default("")
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [employeeCode], onDelete: SetNull, onUpdate: Cascade)
  read       Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([employeeId])
  @@map("notifications")
}
